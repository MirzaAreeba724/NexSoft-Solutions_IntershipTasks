doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Nexsoft Solutions E-Commerce Store
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body.bg-light
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.shadow-sm.mb-4
      .container
        a.navbar-brand.fw-bold(href="/ecommerce") 🛒 NEXSOFT SHOP 
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarsShop")
          span.navbar-toggler-icon
        #navbarsShop.collapse.navbar-collapse
          ul.navbar-nav.me-auto.mb-2.mb-lg-0
            li.nav-item
              a.nav-link(href="/ecommerce") Catalog 
            li.nav-item
              a.nav-link(href="/ecommerce/cart") Cart 
          .d-flex.align-items-center
            if shopUser
              span.navbar-text.text-white.me-3 Welcome, #{shopUser.name}!
              if shopUser.role === 'admin'
                a.btn.btn-outline-warning.btn-sm.me-2(href="/ecommerce/admin") Admin Panel 
              a.btn.btn-danger.btn-sm(href="/ecommerce/logout") Logout 
            else
              a.btn.btn-outline-light.btn-sm(href="/ecommerce/login") Customer Portal 

    .container.mb-5
      block content

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")