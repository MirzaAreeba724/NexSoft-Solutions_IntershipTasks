extends admin-layout

block content
  h1 Add New Movie
  .card
    //- We are using a unique action URL here to avoid conflicts
    form(action="/admin/submit-movie", method="POST")
      div(style="margin-bottom: 15px;")
        label(style="display: block;") Movie Title
        input(type="text", name="title", required, style="width: 100%; padding: 8px;")
      div(style="margin-bottom: 15px;")
        label(style="display: block;") Genre
        input(type="text", name="genre", style="width: 100%; padding: 8px;")
      div(style="margin-bottom: 15px;")
        label(style="display: block;") Release Year
        input(type="number", name="year", style="width: 100%; padding: 8px;")
      button(type="submit", style="padding: 10px 20px; background: #2563eb; color: white; border: none; border-radius: 5px;") Save Movie