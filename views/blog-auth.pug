extends blog-layout

block content
  div(style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 40px; margin-top: 20px;")
    
    // Login Card
    .card
      h2 Log In
      if loginError
        .error-alert #{loginError}
      if success
        .success-alert #{success}

      form(action="/blog/login", method="POST")
        .form-group
          label Email
          input.form-control(type="email", name="email", required)
        .form-group
          label Password
          input.form-control(type="password", name="password", required)
        button.btn(type="submit" style="width: 100%;") Log In

    // Register Card
    .card
      h2 Register
      if registerError
        .error-alert #{registerError}

      form(action="/blog/register", method="POST")
        .form-group
          label Username
          input.form-control(type="text", name="username", required)
        .form-group
          label Email
          input.form-control(type="email", name="email", required)
        .form-group
          label Password
          input.form-control(type="password", name="password", required)
        button.btn(type="submit" style="width: 100%;") Create Account